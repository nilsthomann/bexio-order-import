<Window x:Class="BexioOrderImport.Wpf.Views.CustomerConfirmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lex="clr-namespace:BexioOrderImport.Wpf.Resources"
        Title="{x:Static lex:Translations.CustomerConfirm_Title}" 
        Height="440" Width="560" 
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">
    
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <TextBlock Text="{x:Static lex:Translations.CustomerConfirm_Title}" 
                   Style="{StaticResource SectionHeaderTextBlockStyle}"
                   FontSize="18" Grid.Row="0"/>
        
        <TextBlock Text="{x:Static lex:Translations.CustomerConfirm_Warning}" 
                   Style="{StaticResource MutedTextBlockStyle}" 
                   TextWrapping="Wrap" Margin="0,0,0,16" Grid.Row="1"/>
        
        <!-- Editable Fields -->
        <Border Style="{StaticResource CardBorderStyle}" Grid.Row="2" Margin="0" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" MinHeight="40"/>
                    <RowDefinition Height="Auto" MinHeight="40"/>
                    <RowDefinition Height="Auto" MinHeight="40"/>
                    <RowDefinition Height="Auto" MinHeight="40"/>
                    <RowDefinition Height="Auto" MinHeight="40"/>
                </Grid.RowDefinitions>

                <TextBlock Text="{x:Static lex:Translations.Dialog_Email}" VerticalAlignment="Center" Grid.Row="0" Grid.Column="0"/>
                <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" IsEnabled="False"/>

                <TextBlock Text="{x:Static lex:Translations.Dialog_CustomerName}" VerticalAlignment="Center" Grid.Row="1" Grid.Column="0"/>
                <TextBox Text="{Binding CompanyName, UpdateSourceTrigger=PropertyChanged}" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center"/>
                
                <TextBlock Text="{x:Static lex:Translations.Dialog_Street}" VerticalAlignment="Center" Grid.Row="2" Grid.Column="0"/>
                <TextBox Text="{Binding Street, UpdateSourceTrigger=PropertyChanged}" Grid.Row="2" Grid.Column="1" VerticalAlignment="Center"/>
                
                <TextBlock Text="{x:Static lex:Translations.Dialog_Zip}" VerticalAlignment="Center" Grid.Row="3" Grid.Column="0"/>
                <TextBox Text="{Binding ZipCode, UpdateSourceTrigger=PropertyChanged}" Grid.Row="3" Grid.Column="1" VerticalAlignment="Center"/>
                
                <TextBlock Text="{x:Static lex:Translations.Dialog_City}" VerticalAlignment="Center" Grid.Row="4" Grid.Column="0"/>
                <TextBox Text="{Binding City, UpdateSourceTrigger=PropertyChanged}" Grid.Row="4" Grid.Column="1" VerticalAlignment="Center"/>
             </Grid>
        </Border>
        
        <!-- Actions -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Row="3" Margin="0,16,0,0">
            <Button Content="{x:Static lex:Translations.CustomerConfirm_CancelButton}" 
                    Click="CancelButton_Click"
                    Style="{StaticResource SecondaryButtonStyle}" 
                    Margin="0,0,12,0" Width="140"/>
            <Button Content="{x:Static lex:Translations.CustomerConfirm_CreateButton}" 
                    Click="CreateButton_Click"
                    Style="{StaticResource ModernButtonStyle}" 
                    Width="200" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>
