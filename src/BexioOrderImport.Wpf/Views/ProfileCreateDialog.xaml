<Window x:Class="BexioOrderImport.Wpf.Views.ProfileCreateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lex="clr-namespace:BexioOrderImport.Wpf.Resources"
        Title="{x:Static lex:Translations.Settings_ProfilesCreateTitle}"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="Manual"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        ShowInTaskbar="False">

    <Grid>
        <!-- Backdrop -->
        <Rectangle Fill="#99000000"/>

        <!-- Dialog Card -->
        <Border Width="440"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{StaticResource BackgroundBrush}"
                CornerRadius="12"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.25" BlurRadius="32" ShadowDepth="8" Direction="270"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" CornerRadius="12,12,0,0" Padding="20,14"
                        Background="{StaticResource SidebarBrush}">
                    <Grid>
                        <TextBlock x:Name="TitleTextBlock"
                                   Text="{x:Static lex:Translations.Settings_ProfilesCreateTitle}"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"
                                   VerticalAlignment="Center"/>
                        <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                                Click="Cancel_Click"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Width="28" Height="28" Padding="0" BorderThickness="0"
                                ToolTip="Schliessen">
                            <Path Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"
                                  Fill="{StaticResource TextMutedBrush}" Stretch="Uniform" Width="12" Height="12"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- Separator -->
                <Border Grid.Row="1" Height="1" Background="{StaticResource BorderBrush}"/>

                <!-- Body -->
                <StackPanel Grid.Row="2" Margin="20,16,20,20">
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{x:Static lex:Translations.Settings_ProfileNameLabel}"
                                   VerticalAlignment="Center" Margin="0,0,12,0" FontWeight="Medium"/>
                        <TextBox x:Name="ProfileNameInput" Grid.Column="1" Height="36"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="{x:Static lex:Translations.Dialog_Cancel}" Click="Cancel_Click"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Width="100" Height="34" Margin="0,0,8,0"/>
                        <Button x:Name="ActionButton" Content="{x:Static lex:Translations.Dialog_Create}"
                                Click="Create_Click"
                                Style="{StaticResource ModernButtonStyle}"
                                Width="100" Height="34"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
